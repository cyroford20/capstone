# OpenWeather API Key
# Get your free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your-api-key-here

# Django Settings
DEBUG=True
SECRET_KEY=change-me-to-a-random-50-char-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings (MySQL via WAMP — leave DB_NAME empty for SQLite)
DB_NAME=
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# Firebase (paths relative to backend/ or absolute)
FIREBASE_CREDENTIAL_PATH=../shrimplysmart-firebase-adminsdk-fbsvc-53c8e6c60c.json
FIREBASE_DB_URL=https://shrimplysmart-default-rtdb.firebaseio.com

# Device authentication (JSON map of device-id -> token)
DEVICE_SECRETS={"device-1":"my-super-secret-token"}